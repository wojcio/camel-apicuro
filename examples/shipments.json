{
  "description": "25 Shipment Request Examples for bookstore API",
  "base_url": "http://localhost:8081/api/orders",
  "note": "Shipments are typically created after orders, this shows the shipment event structure"
}
---
# Example 1: Shipment for ORD-001 (Standard)
curl -X POST "http://localhost:8081/api/orders" \
  -H "Content-Type: application/json" \
  -d '{
    "eventId": "2024123456789-SHIP-001",
    "eventType": "SHIPMENT_CREATED",
    "timestamp": 2024-04-15T10:30:00.000Z,
    "shipment": {
      "shipmentId": "SHIP-ORD001-001",
      "orderId": "ORD-001",
      "carrier": "UPS Ground",
      "serviceLevel": "Standard",
      "trackingNumber": "1Z999AA10123456784",
      "estimatedDelivery": "2024-04-19"
    }
  }'

