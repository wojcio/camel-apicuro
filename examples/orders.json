{
  "description": "25 Order Request Examples for bookstore API",
  "base_url": "http://localhost:8081/api/orders",
  "endpoints": {
    "get_all": "/api/orders",
    "get_by_id": "/api/orders/{orderId}",
    "get_items": "/api/orders/{orderId}/items",
    "create_order": "/api/orders"
  }
}
---
# Example 1: Get all orders
curl -X GET "http://localhost:8081/api/orders"

---
# Example 2: Get order by ID
curl -X GET "http://localhost:8081/api/orders/ORD-001"

---
# Example 3: Get order items
curl -X GET "http://localhost:8081/api/orders/ORD-001/items"

---
# Example 4: Create order with single item
curl -X POST "http://localhost:8081/api/orders" \
  -H "Content-Type: application/json" \
  -d '{
    "orderId": "ORD-CUST001-2024-001",
    "customerId": "CUST-001",
    "items": [
      {
        "isbn": "9781234567890",
        "quantity": 1,
        "unitPrice": 49.99
      }
    ],
    "subtotal": 49.99,
    "tax": 4.00,
    "shippingCost": 5.99,
    "totalAmount": 59.98,
    "shippingAddress": {
      "street": "123 Main Street",
      "city": "New York",
      "state": "NY",
      "zipCode": "10001",
      "country": "US"
    }
  }'

---
