{
  "description": "25 Book Request Examples for bookstore API",
  "base_url": "http://localhost:8081/api/books",
  "endpoints": {
    "get_all": "/api/books",
    "get_by_isbn": "/api/books/{isbn}",
    "add_book": "/api/books",
    "update_stock": "/api/books/{isbn}/stock"
  }
}
---
# Example 1: Get all books
curl -X GET "http://localhost:8081/api/books"

---
# Example 2: Get book by ISBN (Technology)
curl -X GET "http://localhost:8081/api/books/9781234567890"

---
# Example 3: Get book by ISBN (Fiction)
curl -X GET "http://localhost:8081/api/books/9781234567900"

---
# Example 4: Get book by ISBN (Science)
curl -X GET "http://localhost:8081/api/books/9781234567910"

---
# Example 5: Get book by ISBN (History)
curl -X GET "http://localhost:8081/api/books/9781234567920"

---
# Example 6: Get book by ISBN (Fantasy)
curl -X GET "http://localhost:8081/api/books/9781234567930"

---
# Example 7: Get book by ISBN (Romance)
curl -X GET "http://localhost:8081/api/books/9781234567940"

---
# Example 8: Add a new book (Technology)
curl -X POST "http://localhost:8081/api/books" \
  -H "Content-Type: application/json" \
  -d '{
    "isbn": "9780000000001",
    "title": "Advanced Spring Boot Patterns",
    "author": "Dev Master",
    "genre": "Technology",
    "price": 59.99,
    "stock": 50,
    "publishedDate": "2024-06-15"
  }'

---
