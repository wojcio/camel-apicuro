  }'

---
# Example 13: Update stock - increase
curl -X PUT "http://localhost:8081/api/books/9781234567890/stock" \
  -H "Content-Type: application/json" \
  -d '{
    "stock": 25
  }'

---
# Example 14: Update stock - decrease (negative)
curl -X PUT "http://localhost:8081/api/books/9781234567891/stock" \
  -H "Content-Type: application/json" \
  -d '{
    "stock": -10
  }'

