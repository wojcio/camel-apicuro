{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BookstoreEvent",
  "description": "Union schema for all bookstore event types",
  "oneOf": [
    {
      "$ref": "#/$defs/BookAddedEvent"
    },
    {
      "$ref": "#/$defs/OrderCreatedEvent"
    },
    {
      "$ref": "#/$defs/ShipmentCreatedEvent"
    }
  ],
  "$defs": {
    "Book": {
      "type": "object",
      "description": "A book in the bookstore catalog",
      "properties": {
        "isbn": {
          "type": "string",
          "description": "ISBN-13 format (13 digits)",
          "pattern": "^\\d{13}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Book title"
        },
        "author": {
          "type": "string",
          "minLength": 1,
          "description": "Author name"
        },
        "genre": {
          "type": "string",
          "enum": ["Fiction", "Non-Fiction", "Science", "History", "Fantasy", "Romance", "Technology"],
          "description": "Book category"
        },
        "price": {
          "type": "number",
          "minimum": 0,
          "description": "Price in USD"
        },
        "stock": {
          "type": "integer",
          "minimum": 0,
          "description": "Available inventory count"
        },
        "publishedDate": {
          "type": "string",
          "format": "date",
          "description": "Publication date in ISO 8601 format"
        }
      },
      "required": ["isbn", "title", "author", "genre", "price", "stock"]
    },
    "OrderItem": {
      "type": "object",
      "description": "An item in an order",
      "properties": {
        "isbn": {
          "type": "string",
          "description": "ISBN of the book"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Number of copies ordered"
        },
        "unitPrice": {
          "type": "number",
          "minimum": 0,
          "description": "Price per copy at time of order"
        }
      },
      "required": ["isbn", "quantity", "unitPrice"]
    },
    "Customer": {
      "type": "object",
      "description": "Customer information",
      "properties": {
        "customerId": {
          "type": "string",
          "description": "Unique customer identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {"type": "string"},
            "city": {"type": "string"},
            "state": {"type": "string", "pattern": "^[A-Z]{2}$"},
            "zipCode": {"type": "string", "pattern": "^\\d{5}(-\\d{4})?$"},
            "country": {"type": "string", "const": "US"}
          },
          "required": ["street", "city", "state", "zipCode", "country"]
        }
      },
      "required": ["customerId", "name", "email", "address"]
    },
    "BookAddedEvent": {
      "type": "object",
      "description": "Event published when a new book is added to the catalog",
      "properties": {
        "eventId": {
          "type": "string",
          "description": "Unique event identifier"
        },
        "eventType": {
          "type": "string",
          "const": "BOOK_ADDED"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds"
        },
        "book": {
          "$ref": "#/$defs/Book"
        }
      },
      "required": ["eventId", "eventType", "timestamp", "book"]
    },
    "OrderCreatedEvent": {
      "type": "object",
      "description": "Event published when a new order is created",
      "properties": {
        "eventId": {
          "type": "string",
          "description": "Unique event identifier"
        },
        "eventType": {
          "type": "string",
          "const": "ORDER_CREATED"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds"
        },
        "order": {
          "type": "object",
          "properties": {
            "orderId": {
              "type": "string",
              "description": "Unique order identifier"
            },
            "customerId": {
              "type": "string",
              "description": "Customer who placed the order"
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "items": {
                "$ref": "#/$defs/OrderItem"
              }
            },
            "subtotal": {
              "type": "number",
              "minimum": 0,
              "description": "Sum of item prices before tax and shipping"
            },
            "tax": {
              "type": "number",
              "minimum": 0,
              "description": "Sales tax amount"
            },
            "shippingCost": {
              "type": "number",
              "minimum": 0,
              "description": "Shipping and handling fee"
            },
            "totalAmount": {
              "type": "number",
              "minimum": 0,
              "description": "Final amount to pay"
            },
            "shippingAddress": {
              "$ref": "#/$defs/Customer/properties/address"
            }
          },
          "required": ["orderId", "customerId", "items", "subtotal", "tax", "shippingCost", "totalAmount", "shippingAddress"]
        }
      },
      "required": ["eventId", "eventType", "timestamp", "order"]
    },
    "ShipmentCreatedEvent": {
      "type": "object",
      "description": "Event published when a shipment is created for an order",
      "properties": {
        "eventId": {
          "type": "string",
          "description": "Unique event identifier"
        },
        "eventType": {
          "type": "string",
          "const": "SHIPMENT_CREATED"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds"
        },
        "shipment": {
          "type": "object",
          "properties": {
            "shipmentId": {
              "type": "string",
              "description": "Unique shipment identifier"
            },
            "orderId": {
              "type": "string",
              "description": "Associated order identifier"
            },
            "carrier": {
              "type": "string",
              "enum": ["FedEx", "UPS", "USPS", "DHL"],
              "description": "Shipping carrier"
            },
            "serviceLevel": {
              "type": "string",
              "enum": ["Standard", "Expedited", "Priority"],
              "description": "Shipping service level"
            },
            "trackingNumber": {
              "type": "string",
              "description": "Carrier tracking number"
            },
            "estimatedDelivery": {
              "type": "string",
              "format": "date",
              "description": "Estimated delivery date"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "isbn": {"type": "string"},
                  "quantity": {"type": "integer", "minimum": 1}
                },
                "required": ["isbn", "quantity"]
              }
            }
          },
          "required": ["shipmentId", "orderId", "carrier", "serviceLevel", "trackingNumber", "estimatedDelivery", "items"]
        }
      },
      "required": ["eventId", "eventType", "timestamp", "shipment"]
    }
  }
}
