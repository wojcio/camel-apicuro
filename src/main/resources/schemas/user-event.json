{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserEvent",
  "type": "object",
  "properties": {
    "username": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "action": {
      "type": "string",
      "enum": ["LOGIN", "LOGOUT", "PURCHASE"]
    },
    "timestamp": {
      "type": "integer"
    }
  },
  "required": ["username", "email", "action"]
}
