<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns="http://camel.apache.org/schema/spring"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://camel.apache.org/schema/spring https://camel.apache.org/schema/spring/camel-spring.xsd">

    <!-- =========================================
         BOOKSTORE EVENT ROUTES
         Demonstrates Camel EIP patterns with Apicurio Registry and SQLite
         ========================================= -->

    <!-- Route 0: Initialize Database on Startup -->
    <route id="init-database">
        <from uri="timer:init?period=1000&amp;repeatCount=1"/>
        <log message="Initializing database..."/>
        
        <!-- Execute schema creation -->
        <to uri="sql:classpath:db/schema.sql"/>
        
        <!-- Execute sample data insertion -->
        <to uri="sql:classpath:db/data.sql"/>
        
        <log message="Database initialized successfully!"/>
    </route>

    <!-- Route 1: Produce Book Added Events -->
    <route id="produce-book-added">
        <from uri="timer:book-added?period=15000&amp;repeatCount=5"/>
        <setBody>
            <constant>{
                "eventId": "${date:now:yyyyMMddHHmmssSSS}-BOOK-001",
                "eventType": "BOOK_ADDED",
                "timestamp": ${date:now:yyyy-MM-dd'T'HH:mm:ss.SSSZ},
                "book": {
                    "isbn": "9781234567890",
                    "title": "The Art of Java Programming",
                    "author": "Jane Developer",
                    "genre": "Technology",
                    "price": 49.99,
                    "stock": 100,
                    "publishedDate": "2024-01-15"
                }
            }</constant>
        </setBody>
        <log message="Producing BOOK_ADDED event: ${body}"/>
        <to uri="kafka:{{kafka.topic.books}}?brokers={{kafka.brokers}}&amp;valueSerializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaSerializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}&amp;additionalProperties.apicurio.registry.auto-register=true"/>
    </route>

    <!-- Route 2: Produce Order Created Events -->
    <route id="produce-order-created">
        <from uri="timer:order-created?period=20000&amp;repeatCount=3"/>
        <setBody>
            <constant>{
                "eventId": "${date:now:yyyyMMddHHmmssSSS}-ORDER-001",
                "eventType": "ORDER_CREATED",
                "timestamp": ${date:now:yyyy-MM-dd'T'HH:mm:ss.SSSZ},
                "order": {
                    "orderId": "ORD-${date:now:yyyyMMddHHmmssSSS}",
                    "customerId": "CUST-12345",
                    "items": [
                        {
                            "isbn": "9781234567890",
                            "quantity": 2,
                            "unitPrice": 49.99
                        },
                        {
                            "isbn": "9780987654321",
                            "quantity": 1,
                            "unitPrice": 29.99
                        }
                    ],
                    "subtotal": 129.97,
                    "tax": 10.40,
                    "shippingCost": 5.99,
                    "totalAmount": 146.36,
                    "shippingAddress": {
                        "street": "123 Main Street",
                        "city": "New York",
                        "state": "NY",
                        "zipCode": "10001",
                        "country": "US"
                    }
                }
            }</constant>
        </setBody>
        <log message="Producing ORDER_CREATED event: ${body}"/>
        <to uri="kafka:{{kafka.topic.orders}}?brokers={{kafka.brokers}}&amp;valueSerializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaSerializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}&amp;additionalProperties.apicurio.registry.auto-register=true"/>
    </route>

    <!-- Route 3: Consume and Process Orders (EIP Patterns) -->
    <route id="process-orders">
        <from uri="kafka:{{kafka.topic.orders}}?brokers={{kafka.brokers}}&amp;valueDeserializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaDeserializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}&amp;autoOffsetReset=earliest"/>

        <!-- Unmarshal JSON to POJO -->
        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.BookstoreEvent"/>
        </unmarshal>

        <!-- Filter: Only process ORDER_CREATED events -->
        <filter>
            <method ref="orderFilter" method="isOrderCreated"/>
            <log message="Processing ORDER_CREATED event: ${body.eventId}"/>

            <!-- EIP: Split - process each order item individually -->
            <split>
                <simple>${body.payload.items}</simple>

                <!-- EIP: Enrich - add book details from database -->
                <enrich aggregationStrategy="itemAggregationStrategy">
                    <constant>direct:get-book-details</constant>
                </enrich>

                <!-- EIP: Filter - only process in-stock items -->
                <filter>
                    <method ref="inventoryFilter" method="isInStock"/>
                    <log message="Item ${body.isbn} is in stock (qty: ${body.stock})"/>

                    <!-- EIP: Choice - route based on price -->
                    <choice>
                        <when>
                            <simple>${body.price} &gt; 50</simple>
                            <log message="High-value item: ${body.title} ($${body.price})"/>
                        </when>
                        <otherwise>
                            <log message="Standard item: ${body.title} ($${body.price})"/>
                        </otherwise>
                    </choice>

                </filter>
            </split>

            <!-- EIP: Aggregate - collect all items back -->
            <aggregate aggregationStrategy="orderAggregationStrategy" completionSize="2">
                <correlationExpression>
                    <simple>${body.payload.orderId}</simple>
                </correlationExpression>
                <log message="Completed processing order: ${body.payload.orderId}"/>
            </aggregate>

        </filter>

        <!-- Dead Letter Channel for error handling -->
        <onException>
            <exception>java.lang.Exception</exception>
            <handled><constant>true</constant></handled>
            <log message="Error processing order: ${exception.message}"/>
            <to uri="kafka:{{kafka.topic.dlq}}?brokers={{kafka.brokers}}&amp;valueSerializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaSerializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}"/>
        </onException>

    </route>

    <!-- Route 4: Get Book Details from Database (Direct Endpoint) -->
    <route id="get-book-details">
        <from uri="direct:get-book-details"/>

        <!-- Extract ISBN from order item -->
        <setHeader name="isbn">
            <simple>${body.isbn}</simple>
        </setHeader>

        <!-- Query book details from SQLite database -->
        <to uri="sql:SELECT isbn, title, author, genre, price, stock FROM books WHERE isbn = :#isbn?outputType=SelectOne"/>
        
        <!-- Log book details if found -->
        <log message="Book details for ${header.isbn}: ${body}"/>
    </route>

    <!-- Route 5: Process Shipments -->
    <route id="process-shipments">
        <from uri="kafka:{{kafka.topic.shipments}}?brokers={{kafka.brokers}}&amp;valueDeserializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaDeserializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}&amp;autoOffsetReset=earliest"/>

        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.BookstoreEvent"/>
        </unmarshal>

        <filter>
            <method ref="shipmentFilter" method="isShipmentCreated"/>

            <!-- EIP: Transform - format shipping label -->
            <transform>
                <method ref="shipmentFormatter"/>
            </transform>

            <!-- EIP: Filter - different handling for expedited vs standard -->
            <choice>
                <when>
                    <method ref="shipmentFilter" method="isExpedited"/>
                    <log message="EXPEDITED SHIPMENT: ${body} - Priority handling required!"/>
                    <to uri="kafka:{{kafka.topic.expedited}}?brokers={{kafka.brokers}}"/>
                </when>
                <otherwise>
                    <log message="STANDARD SHIPMENT: ${body}"/>
                </otherwise>
            </choice>

        </filter>

    </route>

    <!-- Route 6: Consume All Events and Report Statistics -->
    <route id="consume-and-report">
        <from uri="kafka:{{kafka.topic.books}},{{kafka.topic.orders}},{{kafka.topic.shipments}}?brokers={{kafka.brokers}}&amp;valueDeserializer=io.apicurio.registry.serde.jsonschema.JsonSchemaKafkaDeserializer&amp;additionalProperties.apicurio.registry.url={{apicurio.registry.url}}&amp;autoOffsetReset=earliest&amp;groupId=bookstore-reporter"/>

        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.BookstoreEvent"/>
        </unmarshal>

        <!-- EIP: Aggregate - collect events over time window -->
        <aggregate aggregationStrategy="statisticsAggregationStrategy" completionTimeout="60000">
            <correlationExpression>
                <constant>true</constant>
            </correlationExpression>

            <log message="=== BOOKSTORE STATISTICS ==="/>
            <log message="Books Added: ${body.booksAdded}"/>
            <log message="Orders Processed: ${body.ordersProcessed}"/>
            <log message="Shipments Created: ${body.shipmentsCreated}"/>
            <log message="Total Revenue: $${body.totalRevenue}"/>

        </aggregate>

    </route>

    <!-- =========================================
         DIRECT ROUTES FOR API OPERATIONS (Moved from api.xml)
         ========================================= -->

    <!-- Add a new book to database -->
    <route id="add-book">
        <from uri="direct:add-book"/>
        
        <!-- Unmarshal JSON to Book POJO -->
        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.Book"/>
        </unmarshal>
        
        <!-- Insert book into database -->
        <to uri="sql:INSERT INTO books (isbn, title, author, genre, price, stock, published_date) VALUES (:#{body.isbn}, :#{body.title}, :#{body.author}, :#{body.genre}, :#{body.price}, :#{body.stock}, :#{body.publishedDate})"/>
        
        <!-- Return success response -->
        <setHeader name="CamelHttpResponseCode">
            <constant>201</constant>
        </setHeader>
        <setBody>
            <simple>{"message": "Book added successfully", "isbn": "${body.isbn}"}</simple>
        </setBody>
    </route>

    <!-- Update book stock -->
    <route id="update-stock">
        <from uri="direct:update-stock"/>
        
        <!-- Extract ISBN from path -->
        <setHeader name="isbn">
            <simple>${header.isbn}</simple>
        </setHeader>
        
        <!-- Unmarshal JSON body for quantity -->
        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.Book"/>
        </unmarshal>
        
        <!-- Update stock in database -->
        <setBody>
            <simple>${body.stock}</simple>
        </setBody>
        
        <!-- Check if book exists and update stock -->
        <to uri="sql:UPDATE books SET stock = stock + :#stock WHERE isbn = :#isbn"/>
        
        <!-- Check if update was successful -->
        <choice>
            <when>
                <simple>${body} &gt; 0</simple>
                <setHeader name="CamelHttpResponseCode">
                    <constant>200</constant>
                </setHeader>
                <to uri="sql:SELECT isbn, title, author, genre, price, stock FROM books WHERE isbn = :#isbn?outputType=SelectOne"/>
            </when>
            <otherwise>
                <setHeader name="CamelHttpResponseCode">
                    <constant>404</constant>
                </setHeader>
                <setBody>
                    <simple>{"error": "Book not found or invalid stock update"}</simple>
                </setBody>
            </otherwise>
        </choice>
    </route>

    <!-- Create a new order -->
    <route id="create-order">
        <from uri="direct:create-order"/>
        
        <!-- Unmarshal JSON to Order POJO -->
        <unmarshal>
            <json library="Jackson" unmarshalType="com.example.bookstore.models.Order"/>
        </unmarshal>
        
        <!-- Validate order -->
        <choice>
            <when>
                <method ref="orderValidator" method="isValid"/>
                
                <!-- Insert order into database -->
                <to uri="sql:INSERT INTO orders (order_id, customer_id, subtotal, tax, shipping_cost, total_amount, shipping_address) VALUES (:#{body.orderId}, :#{body.customerId}, :#{body.subtotal}, :#{body.tax}, :#{body.shippingCost}, :#{body.totalAmount}, :#{body.shippingAddress})"/>
                
                <!-- Insert order items -->
                <split>
                    <simple>${body.items}</simple>
                    <to uri="sql:INSERT INTO order_items (order_id, isbn, quantity, unit_price) VALUES (:#{body.orderId}, :#{body.isbn}, :#{body.quantity}, :#{body.unitPrice})"/>
                </split>
                
                <!-- Return success response -->
                <setHeader name="CamelHttpResponseCode">
                    <constant>201</constant>
                </setHeader>
                <setBody>
                    <simple>{"message": "Order created successfully", "orderId": "${body.orderId}", "totalAmount": ${body.totalAmount}}</simple>
                </setBody>
                
            </when>
            <otherwise>
                <setHeader name="CamelHttpResponseCode">
                    <constant>400</constant>
                </setHeader>
                <setBody>
                    <simple>{"error": "Invalid order: must have at least one item"}</simple>
                </setBody>
            </otherwise>
        </choice>
    </route>

</routes>
