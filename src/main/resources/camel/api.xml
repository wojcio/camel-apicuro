<?xml version="1.0" encoding="UTF-8"?>
<rests xmlns="http://camel.apache.org/schema/spring"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://camel.apache.org/schema/spring https://camel.apache.org/schema/spring/camel-spring.xsd">

    <!-- =========================================
         BOOKSTORE REST API
         Provides HTTP endpoints for managing books and orders
         ========================================= -->

    <!-- =========================================
         BOOK ENDPOINTS
         ========================================= -->

    <rest path="/api/books" description="Book management API">
        <!-- Get all books -->
        <get path="" produces="application/json" description="Get all books">
            <to uri="sql:SELECT isbn, title, author, genre, price, stock FROM books ORDER BY title"/>
        </get>

        <!-- Get book by ISBN -->
        <get path="/{isbn}" produces="application/json" description="Get a book by ISBN">
            <to uri="sql:SELECT isbn, title, author, genre, price, stock FROM books WHERE isbn = :#isbn?outputType=SelectOne"/>
        </get>

        <!-- Add a new book -->
        <post path="" consumes="application/json" produces="application/json" description="Add a new book">
            <to uri="direct:add-book"/>
        </post>

        <!-- Update book stock -->
        <put path="/{isbn}/stock" consumes="application/json" produces="application/json" description="Update book stock">
            <to uri="direct:update-stock"/>
        </put>
    </rest>

    <!-- =========================================
         ORDER ENDPOINTS
         ========================================= -->

    <rest path="/api/orders" description="Order management API">
        <!-- Get all orders -->
        <get path="" produces="application/json" description="Get all orders">
            <to uri="sql:SELECT order_id, customer_id, order_date, subtotal, tax, shipping_cost, total_amount FROM orders ORDER BY order_date DESC"/>
        </get>

        <!-- Get order by ID -->
        <get path="/{orderId}" produces="application/json" description="Get an order by ID">
            <to uri="sql:SELECT order_id, customer_id, order_date, subtotal, tax, shipping_cost, total_amount FROM orders WHERE order_id = :#orderId?outputType=SelectOne"/>
        </get>

        <!-- Get order items -->
        <get path="/{orderId}/items" produces="application/json" description="Get order items">
            <to uri="sql:SELECT oi.id, oi.order_id, oi.isbn, b.title, oi.quantity, oi.unit_price FROM order_items oi JOIN books b ON oi.isbn = b.isbn WHERE oi.order_id = :#orderId"/>
        </get>

        <!-- Create a new order -->
        <post path="" consumes="application/json" produces="application/json" description="Create a new order">
            <to uri="direct:create-order"/>
        </post>
    </rest>

</rests>
